           rdfs:subClassOf :Object ;
           rdfs:label "Substance"@en ;
           <http://www.w3.org/2004/02/skos/core#definition> "A material, fluid, powder, gas, food, poison, medicine, bodily material, or other substance-like entity."@en ;
           <http://www.w3.org/2004/02/skos/core#example> "the poison, the blood, the ashes, the water, the smoke, the potion, the dust."@en ;
           <http://www.w3.org/2004/02/skos/core#prefLabel> "Substance"@en .


